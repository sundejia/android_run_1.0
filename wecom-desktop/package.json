{
  "name": "wecom-desktop",
  "version": "1.0.0",
  "description": "WeCom Automation Desktop App - Device mirroring and sync orchestration",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "backend": "cd backend && uv run uvicorn main:app --reload --port 8765",
    "start": "concurrently \"npm run backend\" \"npm run dev:electron\"",
    "lint": "eslint --ext .vue,.ts,.tsx,.js src/",
    "lint:fix": "eslint --fix --ext .vue,.ts,.tsx,.js src/",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,json,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run"
  },
  "lint-staged": {
    "src/**/*.{vue,ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@vueuse/core": "^10.7.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.5.32",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-vite": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.21.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.4"
  }
}
