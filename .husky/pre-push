#!/bin/sh

# Skip hooks in CI environment
if [ "$CI" = "true" ]; then
  echo "⏭️  Skipping pre-push hook in CI environment"
  exit 0
fi

echo "🚀 Running pre-push checks..."

# If the git root is one level above the project, cd into the project directory
if [ -d "android_run_test-main/wecom-desktop" ] && [ ! -d "wecom-desktop" ]; then
  cd android_run_test-main
fi

# Type checking for frontend
echo "📘 Running TypeScript type check..."
cd wecom-desktop && npx vue-tsc --noEmit
TYPECHECK_EXIT=$?
cd ..

if [ $TYPECHECK_EXIT -ne 0 ]; then
  echo "❌ TypeScript type check failed. Please fix type errors before pushing."
  exit 1
fi

# Run Python unit tests (fast tests only)
echo "🧪 Running Python unit tests..."
# Prefer system Python on hosts where the project's binary deps (e.g. pilk)
# can't be rebuilt cleanly inside a fresh uv venv (Windows without MSVC build
# tools). uv is still the recommended path; we fall through to it only if a
# system Python with pytest is unavailable.
PYTEST_RUNNER=""
if command -v python > /dev/null 2>&1 && python -c "import pytest" >/dev/null 2>&1; then
  PYTEST_RUNNER="python"
elif command -v uv > /dev/null 2>&1; then
  PYTEST_RUNNER="uv run --extra dev python"
else
  echo "❌ No usable Python+pytest found. Install pytest in your system Python or set up uv with the project's dev deps."
  exit 1
fi

$PYTEST_RUNNER -c "import pathlib, sys, pytest; root = pathlib.Path.cwd(); sys.path[:0] = [str(root / 'src'), str(root / 'wecom-desktop' / 'backend')]; raise SystemExit(pytest.main(['tests/unit', '-v', '--tb=short', '-q']))"
PYTEST_EXIT=$?

if [ $PYTEST_EXIT -ne 0 ]; then
  echo "❌ Python unit tests failed. Please fix failing tests before pushing."
  exit 1
fi

echo "✅ Pre-push checks passed!"
exit 0
