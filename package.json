{
  "name": "wecom-automation",
  "version": "1.0.0",
  "description": "WeCom Automation - Android device automation for WeCom",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint:frontend && npm run lint:python",
    "lint:frontend": "cd wecom-desktop && npx eslint --ext .vue,.ts,.tsx,.js src/",
    "lint:python": "python -m ruff check src/ wecom-desktop/backend/",
    "format": "npm run format:frontend && npm run format:python",
    "format:frontend": "cd wecom-desktop && npx prettier --write \"src/**/*.{vue,ts,tsx,js,json,css}\"",
    "format:python": "python -m ruff format src/ wecom-desktop/backend/",
    "typecheck": "cd wecom-desktop && npx vue-tsc --noEmit",
    "test": "npm run test:python",
    "test:python": "pytest tests/ -v --tb=short",
    "test:unit": "pytest tests/unit -v --tb=short"
  },
  "lint-staged": {
    "wecom-desktop/src/**/*.{vue,ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "wecom-desktop/src/**/*.{json,css,scss,md}": [
      "prettier --write"
    ],
    "{src,wecom-desktop/backend}/**/*.py": [
      "ruff check --fix --force-exclude",
      "ruff format --force-exclude"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  }
}
